<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="db/changelog/v91-add-auc-predictions-path-column.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <changeSet id="add_evaluation_log_auc_predictions_path_column" author="roman.batygin@mail.ru" context="schema">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="evaluation_log"/>
            <not>
                <columnExists tableName="evaluation_log" columnName="auc_predictions_path"/>
            </not>
        </preConditions>
        <addColumn tableName="evaluation_log">
            <column name="auc_predictions_path" type="varchar(255)"/>
        </addColumn>
    </changeSet>

    <changeSet id="add_experiment_results_auc_predictions_path_column" author="roman.batygin@mail.ru" context="schema">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="experiment_results"/>
            <not>
                <columnExists tableName="experiment_results" columnName="auc_predictions_path"/>
            </not>
        </preConditions>
        <addColumn tableName="experiment_results">
            <column name="auc_predictions_path" type="varchar(255)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>